# Copy to .env (which is gitignored) and fill in. NEVER commit real values.
# Loaded by venture/security/secrets.py  (precedence: real env var > .env > vault)

# --- New hardened vault master password (for venture/security/vault.py) ------
VENTURE_MASTER_PASSWORD=change-me-to-a-long-random-passphrase
# VENTURE_VAULT_PATH=~/.venture/vault.enc   # optional override

# --- Market / data (use READ-ONLY, NO-WITHDRAWAL keys where possible) --------
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

SUPABASE_URL=
SUPABASE_KEY=

NEWS_API_KEY=
FIRECRAWL_API_KEY=

# --- LLM brain (cloud; used when the local `claude` CLI isn't available, e.g. hosting) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8   # or claude-sonnet-5 / claude-haiku-4-5 to cut cost

# --- Telegram daily-run updates -------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
